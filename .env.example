# Primary RPC — get your key from https://www.alchemy.com/
ALCHEMY_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_KEY

# Deployer wallet private key (without 0x prefix is fine)
PRIVATE_KEY=your_deployer_private_key_here

# Fallback public BSC Testnet RPCs (no key needed)
FALLBACK_RPC_1=https://data-seed-prebsc-1-s1.binance.org:8545
FALLBACK_RPC_2=https://data-seed-prebsc-2-s1.binance.org:8545

# Fill these AFTER deploying the contracts:
TOKEN_ADDRESS=
MULTISENDER_ADDRESS=
